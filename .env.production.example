# Copy this file to .env on the server and fill real values.

# Public domain. DNS A record must point to the server IP before starting Caddy.
DOMAIN=example.com

# Build mirrors for servers with slow access to PyPI or npm.
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
PIP_TRUSTED_HOST=mirrors.aliyun.com
NPM_REGISTRY=https://registry.npmmirror.com

# PostgreSQL container credentials.
POSTGRES_DB=v4corner
POSTGRES_USER=v4corner
POSTGRES_PASSWORD=change-this-postgres-password
DATABASE_URL=postgresql+psycopg2://v4corner:change-this-postgres-password@postgres:5432/v4corner

# Application security.
ENVIRONMENT=production
DEBUG=False
SECRET_KEY=replace-with-output-of-openssl-rand-hex-32
ALLOWED_ORIGINS=https://example.com
SKIP_EMAIL_VERIFICATION=False

# First admin bootstrap. Password must pass the app password rules.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NICKNAME=管理员

# Email verification. Use any SMTP mailbox provider.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USE_SSL=True
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-smtp-authorization-code
SMTP_FROM_ALIAS=V4Corner

# AI provider. Configure one provider, or set AI_PROVIDER explicitly.
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional OpenAI-compatible alternative.
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=
